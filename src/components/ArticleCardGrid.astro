---
interface Props {
  slug: string;
  title: string;
  description: string;
  publishedAt: string;
  category: string;
  thumbnail?: string;
  thumbnailAlt?: string;
  number?: number;
}

const { slug, title, description, publishedAt, category, thumbnail, thumbnailAlt, number } = Astro.props;

const categoryLabels: Record<string, string> = {
  'model-course': 'Model Course',
  'area-guide': 'Area Guide',
  'food': 'Food',
  'activity': 'Activity',
  'tips': 'Tips',
  'seasonal': 'Seasonal',
};

const formatDate = (dateStr: string) => {
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
};

const numStr = number !== undefined ? String(number).padStart(3, '0') : undefined;
---

<a href={`/articles/${slug}/`} class="group block no-underline">
  <article>
    <div class="relative w-full overflow-hidden rounded-[4px] mb-4" style="aspect-ratio: 16/10;">
      {thumbnail ? (
        <img
          src={thumbnail}
          alt={thumbnailAlt || title}
          class="w-full h-full object-cover transition-transform duration-600 group-hover:scale-[1.03]"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full bg-gradient-to-br from-[#ddd] to-[#eee] transition-transform duration-600 group-hover:scale-[1.03]"></div>
      )}
      {numStr && (
        <span class="absolute top-3 left-3 font-['Inter'] text-[9px] tracking-[0.12em] text-white px-2 py-[3px] rounded-[2px]" style="background: rgba(0,0,0,0.35); backdrop-filter: blur(4px);">
          {numStr}
        </span>
      )}
    </div>
    <div class="flex items-center gap-3 mb-2">
      <span class="meta-text">{categoryLabels[category] || category}</span>
      <span class="font-['Inter'] text-[9px] tracking-[0.12em] text-[var(--text-muted)]">{formatDate(publishedAt)}</span>
    </div>
    <h3 class="text-[17px] font-medium leading-[1.5] text-[var(--text)] mb-2 transition-opacity duration-300 group-hover:opacity-60">
      {title}
    </h3>
    <p class="text-[11px] leading-[1.7] text-[#aaa] line-clamp-2">{description}</p>
  </article>
</a>
