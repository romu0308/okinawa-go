---
interface Props {
  darkMode?: boolean;
}

const { darkMode = false } = Astro.props;

const categories = [
  { label: 'Model Course', href: '/articles/?category=model-course' },
  { label: 'Area Guide', href: '/articles/?category=area-guide' },
  { label: 'Food', href: '/articles/?category=food' },
  { label: 'Tips', href: '/articles/?category=tips' },
];

const links = [
  { label: 'About', href: '/about/' },
  { label: 'Privacy', href: '/privacy/' },
  { label: 'Disclaimer', href: '/disclaimer/' },
];
---

<footer class:list={[
  "w-full",
  darkMode ? "border-t border-white/10" : "border-t border-[var(--border)]"
]}>
  <div class="max-w-[1200px] mx-auto px-5 md:px-10 pt-10 pb-6">
    <!-- Categories -->
    <div class="mb-6">
      <span class:list={[
        "font-['Inter'] text-[9px] tracking-[0.15em] uppercase block mb-3",
        darkMode ? "text-white/20" : "text-[var(--text-muted)]"
      ]}>Categories</span>
      <div class="flex flex-wrap gap-x-5 gap-y-2">
        {categories.map((cat) => (
          <a
            href={cat.href}
            class:list={[
              "font-['Inter'] text-[11px] tracking-[0.04em] no-underline transition-opacity duration-300 hover:opacity-60",
              darkMode ? "text-white/40" : "text-[var(--text-secondary)]"
            ]}
          >{cat.label}</a>
        ))}
      </div>
    </div>

    <!-- Quick Links -->
    <div class="mb-6">
      <div class="flex flex-wrap gap-x-5 gap-y-2">
        {links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "font-['Inter'] text-[11px] tracking-[0.04em] no-underline transition-opacity duration-300 hover:opacity-60",
              darkMode ? "text-white/30" : "text-[var(--text-muted)]"
            ]}
          >{link.label}</a>
        ))}
      </div>
    </div>

    <!-- Bottom row: logo + SNS + copyright -->
    <div class:list={[
      "flex items-center justify-between pt-6",
      darkMode ? "border-t border-white/10" : "border-t border-[var(--border)]"
    ]} style="border-width: 0.5px;">
      <a
        href="/"
        class:list={[
          "no-underline transition-opacity duration-300 hover:opacity-60",
          darkMode ? "text-white/30" : "text-[var(--text-tertiary)]"
        ]}
      >
        <span class="font-['Inter'] text-[9px] tracking-[0.15em] uppercase">OKINAWA!GO!!</span>
      </a>

      <div class="flex items-center gap-4">
        <a
          href="https://x.com/KOUMEI_GO"
          target="_blank"
          rel="noopener noreferrer"
          class:list={[
            "font-['Inter'] text-[9px] tracking-[0.12em] no-underline transition-opacity duration-300 hover:opacity-60",
            darkMode ? "text-white/20" : "text-[var(--text-muted)]"
          ]}
        >
          @KOUMEI_GO
        </a>
      </div>
    </div>

    <!-- Copyright -->
    <p class:list={[
      "font-['Inter'] text-[9px] tracking-[0.08em] mt-4 mb-0",
      darkMode ? "text-white/15" : "text-[var(--text-muted)]"
    ]} style="opacity: 0.6;">
      &copy; 2026 OKINAWA!GO!! All rights reserved.
    </p>
  </div>
</footer>
