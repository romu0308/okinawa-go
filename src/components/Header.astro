---
const navLinks = [
  { href: '/articles/?category=area-guide', label: 'Area' },
  { href: '/plan/', label: 'Plan' },
  { href: '/articles/?category=food', label: 'Spot' },
  { href: '/about/', label: 'About' },
];
---

<header class="w-full">
  <div class="mx-auto max-w-[1200px] px-6 md:px-12 py-6 flex items-center justify-between">
    <a href="/" class="text-[var(--color-text-primary)] no-underline hover:opacity-70 transition-opacity duration-300">
      <span class="font-['Inter'] text-[15px] font-medium tracking-[0.02em]">OKINAWA!GO!!</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="nav-text text-[var(--color-text-secondary)] no-underline hover:text-[var(--color-text-primary)] transition-colors duration-300"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col justify-center items-center w-8 h-8 gap-[5px] bg-transparent border-none cursor-pointer"
      aria-label="メニューを開く"
    >
      <span class="hamburger-line block w-5 h-[1px] bg-[var(--color-text-primary)] transition-all duration-300"></span>
      <span class="hamburger-line block w-5 h-[1px] bg-[var(--color-text-primary)] transition-all duration-300"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden fixed inset-0 z-50 bg-[var(--color-bg)]">
    <div class="px-6 py-6 flex items-center justify-between">
      <a href="/" class="text-[var(--color-text-primary)] no-underline">
        <span class="font-['Inter'] text-[15px] font-medium tracking-[0.02em]">OKINAWA!GO!!</span>
      </a>
      <button
        id="menu-close"
        class="flex items-center justify-center w-8 h-8 bg-transparent border-none cursor-pointer"
        aria-label="メニューを閉じる"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M1 1L15 15M15 1L1 15" stroke="currentColor" stroke-width="1"/>
        </svg>
      </button>
    </div>
    <nav class="flex flex-col items-start gap-8 px-6 pt-12">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="nav-text text-[18px] tracking-[0.08em] uppercase text-[var(--color-text-primary)] no-underline"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const close = document.getElementById('menu-close');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    menu?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  });

  close?.addEventListener('click', () => {
    menu?.classList.add('hidden');
    document.body.style.overflow = '';
  });

  // Close on link click
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      document.body.style.overflow = '';
    });
  });
</script>
