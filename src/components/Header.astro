---
interface Props {
  darkMode?: boolean;
}

const { darkMode = false } = Astro.props;

const navLinks = [
  { href: '/articles/', label: 'Work' },
  { href: '/shindan/', label: 'Shindan' },
  { href: '/plan/', label: 'Plan' },
  { href: '/about/', label: 'About' },
];
---

<header class="w-full relative z-50">
  <div class:list={[
    "flex items-center justify-between",
    "px-5 py-[14px] md:px-10 md:py-4"
  ]}>
    <a
      href="/"
      class:list={[
        "no-underline transition-opacity duration-300 hover:opacity-60",
        darkMode ? "text-white" : "text-[var(--text)]"
      ]}
    >
      <span class="font-['Inter'] text-[11px] font-medium tracking-[0.18em] uppercase">OKINAWA!GO!!</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "font-['Inter'] text-[11px] tracking-[0.08em] uppercase no-underline transition-opacity duration-300 hover:opacity-60",
            darkMode ? "text-white/50" : "text-[var(--text-secondary)]"
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col justify-center items-end w-8 h-8 gap-[6px] bg-transparent border-none cursor-pointer"
      aria-label="メニューを開く"
    >
      <span class:list={[
        "block h-[1.5px] transition-all duration-300",
        darkMode ? "bg-white" : "bg-[var(--text)]"
      ]} style="width: 20px"></span>
      <span class:list={[
        "block h-[1.5px] transition-all duration-300",
        darkMode ? "bg-white" : "bg-[var(--text)]"
      ]} style="width: 14px"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden fixed inset-0 z-[100] bg-[#080e14]">
    <div class="px-5 py-[14px] flex items-center justify-between">
      <a href="/" class="text-white no-underline">
        <span class="font-['Inter'] text-[11px] font-medium tracking-[0.18em] uppercase">OKINAWA!GO!!</span>
      </a>
      <button
        id="menu-close"
        class="flex items-center justify-center w-8 h-8 bg-transparent border-none cursor-pointer text-white"
        aria-label="メニューを閉じる"
      >
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="1"/>
        </svg>
      </button>
    </div>
    <nav class="flex flex-col items-start gap-10 px-5 pt-16">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="font-['Inter'] text-[24px] font-medium tracking-[0.04em] uppercase text-white no-underline"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const close = document.getElementById('menu-close');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    menu?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  });

  close?.addEventListener('click', () => {
    menu?.classList.add('hidden');
    document.body.style.overflow = '';
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      document.body.style.overflow = '';
    });
  });
</script>
