---
interface Props {
  variant?: 'default' | 'compact';
}

const { variant = 'default' } = Astro.props;
---

{variant === 'default' ? (
  <div class="my-12 py-8 px-6 rounded-lg text-center" style="background: var(--bg-alt); border: 0.5px solid var(--border);">
    <p class="text-[18px] font-medium text-[var(--text)] mb-2">沖縄旅行プランシート、無料配布中。</p>
    <p class="text-[13px] text-[var(--text-secondary)] mb-6 leading-[1.7]">
      LINEで友だち追加するだけで、在住者が作った沖縄旅行プランシートをプレゼント。
    </p>
    <a
      href="#line-add-friend"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-8 py-3 rounded-full text-white text-[13px] font-medium no-underline transition-opacity hover:opacity-90"
      style="background: #06C755;"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 5.73 2 10.25c0 4.07 3.29 7.47 7.74 8.13.3.06.71.19.82.43.09.22.06.56.03.78l-.13.79c-.04.23-.18.9.79.49s5.27-3.18 7.19-5.44C20.63 13.26 22 11.86 22 10.25 22 5.73 17.52 2 12 2z"/></svg>
      LINEで無料プランシートをもらう
    </a>
    <p class="text-[10px] text-[var(--text-muted)] mt-4">※いつでもブロック解除できます</p>
  </div>
) : (
  <div class="my-6 flex items-center justify-between p-4 rounded-lg" style="background: #f0fdf4; border: 0.5px solid #bbf7d0;">
    <div>
      <p class="text-[13px] font-medium text-[#166534]">沖縄旅行プランシート配布中</p>
      <p class="text-[11px] text-[#15803d]">LINEで無料ゲット</p>
    </div>
    <a href="#line-add-friend" target="_blank" rel="noopener noreferrer"
      class="px-4 py-2 rounded-full text-white text-[11px] font-medium no-underline" style="background: #06C755;">
      追加する
    </a>
  </div>
)}
