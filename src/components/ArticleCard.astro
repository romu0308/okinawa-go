---
interface Props {
  slug: string;
  title: string;
  description: string;
  publishedAt: string;
  category: string;
  thumbnail?: string;
  thumbnailAlt?: string;
}

const { slug, title, description, publishedAt, category, thumbnail, thumbnailAlt } = Astro.props;

const categoryLabels: Record<string, string> = {
  'model-course': 'Model Course',
  'area-guide': 'Area Guide',
  'food': 'Food',
  'activity': 'Activity',
  'tips': 'Tips',
  'seasonal': 'Seasonal',
};

const formatDate = (dateStr: string) => {
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
};
---

<a href={`/articles/${slug}/`} class="group block no-underline">
  <article class="flex items-start justify-between gap-6 py-6">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-3 mb-3">
        <span class="meta-text text-[var(--color-accent)]">
          {categoryLabels[category] || category}
        </span>
        <span class="meta-text text-[var(--color-text-tertiary)]">
          {formatDate(publishedAt)}
        </span>
      </div>
      <h3 class="text-[16px] md:text-[18px] font-medium leading-[1.5] text-[var(--color-text-primary)] mb-2 group-hover:opacity-70 transition-opacity duration-300">
        {title}
      </h3>
      <p class="text-[13px] leading-[1.8] text-[var(--color-text-secondary)] line-clamp-2 hidden md:block">
        {description}
      </p>
    </div>
    <div class="shrink-0 w-20 h-14 rounded-[6px] overflow-hidden bg-gradient-to-br from-[var(--color-accent)] to-[var(--color-accent-light)]">
      {thumbnail ? (
        <img src={thumbnail} alt={thumbnailAlt || title} class="w-full h-full object-cover" loading="lazy" />
      ) : (
        <div class="w-full h-full"></div>
      )}
    </div>
  </article>
</a>
