---
export const prerender = false;

import { isAuthenticated } from '../lib/auth';

if (!isAuthenticated(Astro.cookies)) {
  return Astro.redirect('/admin/login');
}

interface Props {
  title?: string;
}

const { title = '管理画面' } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/admin', icon: '\u{1F4CA}', label: '\u30C0\u30C3\u30B7\u30E5\u30DC\u30FC\u30C9' },
  { href: '/admin/articles', icon: '\u{1F4DD}', label: '\u8A18\u4E8B\u7BA1\u7406' },
  { href: '/admin/companies', icon: '\u{1F3E2}', label: '\u30DB\u30EF\u30A4\u30C8\u4F01\u696D' },
  { href: '/admin/affiliates', icon: '\u{1F517}', label: '\u30A2\u30D5\u30A3\u30EA\u30A8\u30A4\u30C8' },
  { href: '/admin/spots', icon: '\u{1F4CD}', label: '\u30B9\u30DD\u30C3\u30C8' },
  { href: '/admin/reviews', icon: '\u2B50', label: '\u30EC\u30D3\u30E5\u30FC' },
  { href: '/admin/newsletters', icon: '\u{1F4E7}', label: '\u30CB\u30E5\u30FC\u30B9\u30EC\u30BF\u30FC' },
  { href: '/admin/media', icon: '\u{1F5BC}\uFE0F', label: '\u30E1\u30C7\u30A3\u30A2' },
  { href: '/admin/settings', icon: '\u2699\uFE0F', label: '\u8A2D\u5B9A' },
];

function isActive(href: string): boolean {
  if (href === '/admin') return currentPath === '/admin' || currentPath === '/admin/';
  return currentPath.startsWith(href);
}
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} - キャリア孔明</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
  <style is:global>
    @import "tailwindcss";

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Noto Sans JP', sans-serif;
      background-color: #f3f4f6;
    }
  </style>
</head>
<body class="min-h-screen">
  <!-- Mobile overlay -->
  <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden" onclick="toggleSidebar()"></div>

  <!-- Sidebar -->
  <aside id="sidebar" class="fixed top-0 left-0 h-full w-60 bg-[#1f2937] text-white z-50 transform -translate-x-full lg:translate-x-0 transition-transform duration-200">
    <div class="p-5 border-b border-gray-700">
      <h1 class="text-base font-bold tracking-wide">キャリア孔明</h1>
      <p class="text-xs text-gray-400 mt-1">Admin Panel</p>
    </div>
    <nav class="py-4">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'flex items-center gap-3 px-5 py-3 text-sm transition-colors',
            isActive(item.href) ? 'bg-gray-700 text-white' : 'text-gray-300 hover:bg-gray-700/50 hover:text-white',
          ]}
        >
          <span class="text-lg">{item.icon}</span>
          <span>{item.label}</span>
        </a>
      ))}
    </nav>
  </aside>

  <!-- Main wrapper -->
  <div class="lg:ml-60 min-h-screen flex flex-col">
    <!-- Header -->
    <header class="sticky top-0 z-30 bg-white border-b border-gray-200 px-4 lg:px-6 h-14 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <button
          id="hamburger"
          class="lg:hidden p-2 -ml-2 rounded hover:bg-gray-100"
          onclick="toggleSidebar()"
          aria-label="メニュー"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
        <span class="text-sm font-medium text-gray-700">キャリア孔明 管理画面</span>
      </div>
      <form method="POST" action="/api/admin/auth" id="logout-form">
        <input type="hidden" name="_method" value="DELETE" />
        <button
          type="button"
          onclick="doLogout()"
          class="text-sm text-gray-500 hover:text-gray-700 px-3 py-1.5 rounded hover:bg-gray-100 transition-colors"
        >
          ログアウト
        </button>
      </form>
    </header>

    <!-- Content -->
    <main class="flex-1 p-4 lg:p-6">
      <slot />
    </main>
  </div>

  <script is:inline>
    function toggleSidebar() {
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('sidebar-overlay');
      sidebar.classList.toggle('-translate-x-full');
      overlay.classList.toggle('hidden');
    }

    async function doLogout() {
      await fetch('/api/admin/auth', { method: 'DELETE' });
      window.location.href = '/admin/login';
    }
  </script>
</body>
</html>
