---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';

const tools = [
  {
    title: '年収シミュレーション',
    href: '/tools/salary',
    description: 'あなたのスキルと経験から適正年収を算出',
    icon: 'salary',
    color: 'blue',
  },
  {
    title: 'ブラック度チェック',
    href: '/tools/escape',
    description: '今の職場、本当に大丈夫？',
    icon: 'escape',
    color: 'red',
  },
  {
    title: '市場価値診断',
    href: '/tools/market-value',
    description: '転職市場でのあなたの価値を可視化',
    icon: 'market',
    color: 'purple',
  },
];
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="キャリア診断ツール"
    description="年収シミュレーション、ブラック度チェック、市場価値診断。あなたのキャリアを数値で可視化する無料ツール。"
  />

  <section class="px-5 md:px-10 pt-16 md:pt-24 pb-20 md:pb-28 max-w-[780px] mx-auto">
    <span class="label-text block mb-3 reveal">Tools</span>
    <h1 class="text-[24px] md:text-[32px] font-medium leading-[1.3] tracking-[-0.02em] text-[var(--text)] mb-4 reveal">
      キャリア診断ツール
    </h1>
    <p class="text-[14px] md:text-[16px] leading-[1.8] text-[#666] mb-12 reveal">
      あなたのキャリアを数値で可視化。全て無料で利用できます。
    </p>

    <div class="space-y-4">
      {tools.map((tool) => (
        <a
          href={tool.href}
          class="block p-6 md:p-8 border border-[var(--border)] rounded-lg no-underline hover:border-[#ccc] transition-all duration-300 group reveal"
        >
          <div class="flex items-start gap-5">
            <div class:list={[
              "w-12 h-12 rounded-lg flex items-center justify-center shrink-0",
              tool.color === 'blue' && 'bg-blue-50',
              tool.color === 'red' && 'bg-red-50',
              tool.color === 'purple' && 'bg-purple-50',
            ]}>
              {tool.icon === 'salary' && (
                <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              )}
              {tool.icon === 'escape' && (
                <svg class="w-6 h-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                </svg>
              )}
              {tool.icon === 'market' && (
                <svg class="w-6 h-6 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
                </svg>
              )}
            </div>
            <div>
              <h2 class="text-[17px] md:text-[19px] font-medium text-[var(--text)] mb-1 group-hover:opacity-70 transition-opacity duration-300">
                {tool.title}
              </h2>
              <p class="text-[13px] md:text-[14px] text-[#888] !mb-0">{tool.description}</p>
            </div>
            <svg class="w-5 h-5 text-[#ccc] shrink-0 ml-auto mt-1 group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
