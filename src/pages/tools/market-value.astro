---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import MarketValue from '../../components/tools/MarketValue';
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="市場価値診断"
    description="転職市場でのあなたの価値を可視化。職種・スキル・経験年数から市場価値スコアを算出します。"
  />

  <section class="px-5 md:px-10 pt-16 md:pt-24 pb-20 md:pb-28 max-w-[680px] mx-auto">
    <a href="/tools" class="label-text no-underline hover:opacity-60 transition-opacity duration-300 block mb-3 reveal">
      &larr; Tools
    </a>
    <h1 class="text-[24px] md:text-[32px] font-medium leading-[1.3] tracking-[-0.02em] text-[var(--text)] mb-4 reveal">
      市場価値診断
    </h1>
    <p class="text-[14px] md:text-[16px] leading-[1.8] text-[#666] mb-10 reveal">
      転職市場でのあなたの価値をS〜Dランクで可視化します。
    </p>
    <MarketValue client:load />
  </section>
</BaseLayout>
