---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="AI Trip Planner"
    description="沖縄在住者AIが、あなたの旅をプランニング。Coming Soon."
  />

  <section class="px-6 md:px-12 pt-24 md:pt-32 pb-24 md:pb-32 max-w-[780px] mx-auto text-center">
    <p class="meta-text text-[var(--color-accent)] mb-6">AI Trip Planner</p>
    <h1 class="text-[28px] md:text-[32px] font-medium leading-[1.3] tracking-[-0.01em] text-[var(--color-text-primary)] mb-6">
      Coming Soon
    </h1>
    <p class="text-[14px] md:text-[16px] leading-[1.9] text-[var(--color-text-secondary)] max-w-[480px] mx-auto mb-10">
      沖縄在住者の知識を学習したAIが、あなただけのオリジナル旅行プランを作成します。もうしばらくお待ちください。
    </p>
    <a
      href="/"
      class="inline-block meta-text text-[var(--color-text-secondary)] no-underline hover:text-[var(--color-text-primary)] transition-colors duration-300"
    >
      ← Back to Home
    </a>
  </section>
</BaseLayout>
