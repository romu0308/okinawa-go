---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sortedArticles = allArticles.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);
const featuredArticle = sortedArticles.find((a) => a.data.featured) || sortedArticles[0];
const latestArticles = sortedArticles.filter((a) => a.id !== featuredArticle?.id).slice(0, 5);
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="OKINAWA!GO!!"
    description="住んでるからこそわかる沖縄がある。沖縄在住フリーランスが、ガイドブックに載らない沖縄の楽しみ方を発信。"
    ogType="website"
  />

  <!-- Hero -->
  <section class="px-6 md:px-12 pt-16 md:pt-24 pb-20 md:pb-28 max-w-[1200px] mx-auto">
    <p class="meta-text text-[var(--color-accent)] mb-6">Okinawa Local Guide</p>
    <h1 class="text-[28px] md:text-[40px] font-medium leading-[1.3] tracking-[-0.01em] text-[var(--color-text-primary)] mb-6">
      住んでるからこそ<br />わかる沖縄がある。
    </h1>
    <p class="text-[14px] md:text-[16px] leading-[1.9] text-[var(--color-text-secondary)] max-w-[540px]">
      沖縄在住フリーランスが、ガイドブックに載らない沖縄の楽しみ方を発信。地元民の目線で、あなただけの旅を。
    </p>
  </section>

  <!-- Featured Article -->
  {featuredArticle && (
    <section class="px-6 md:px-12 max-w-[1200px] mx-auto mb-20 md:mb-28">
      <a href={`/articles/${featuredArticle.id}/`} class="group block relative overflow-hidden rounded-[6px]">
        <div class="w-full aspect-[16/9] md:aspect-[21/9] bg-gradient-to-br from-[#1A6B7A] via-[#2A8B9A] to-[#E1F0F2]">
          {featuredArticle.data.thumbnail && (
            <img
              src={featuredArticle.data.thumbnail}
              alt={featuredArticle.data.thumbnailAlt}
              class="w-full h-full object-cover group-hover:opacity-90 transition-opacity duration-300"
              loading="eager"
            />
          )}
        </div>
        <div class="absolute bottom-0 left-0 right-0 p-6 md:p-10 bg-gradient-to-t from-black/60 to-transparent">
          <span class="meta-text text-white/80 mb-3 block">
            {featuredArticle.data.category === 'model-course' ? 'Model Course' : featuredArticle.data.category}
          </span>
          <h2 class="text-[18px] md:text-[24px] font-medium leading-[1.4] text-white">
            {featuredArticle.data.title}
          </h2>
        </div>
      </a>
    </section>
  )}

  <!-- Latest Articles -->
  <section class="px-6 md:px-12 max-w-[1200px] mx-auto mb-20 md:mb-28">
    <p class="meta-text text-[var(--color-text-tertiary)] mb-10">Latest Articles</p>
    <div class="divide-y divide-[var(--color-border)]">
      {latestArticles.map((article) => (
        <ArticleCard
          slug={article.id}
          title={article.data.title}
          description={article.data.description}
          publishedAt={article.data.publishedAt}
          category={article.data.category}
          thumbnail={article.data.thumbnail}
          thumbnailAlt={article.data.thumbnailAlt}
        />
      ))}
    </div>
    <div class="mt-10">
      <a
        href="/articles/"
        class="inline-block meta-text text-[var(--color-text-secondary)] no-underline hover:text-[var(--color-text-primary)] transition-colors duration-300"
      >
        View All Articles →
      </a>
    </div>
  </section>

  <!-- AI Trip Planner -->
  <section class="bg-[var(--color-accent-light)] py-20 md:py-28 mb-0">
    <div class="px-6 md:px-12 max-w-[1200px] mx-auto">
      <p class="meta-text text-[var(--color-accent)] mb-6">AI Trip Planner</p>
      <h2 class="text-[24px] md:text-[32px] font-medium leading-[1.3] tracking-[-0.01em] text-[var(--color-text-primary)] mb-4">
        沖縄在住者AIが、<br class="md:hidden" />あなたの旅をプランニング。
      </h2>
      <p class="text-[14px] md:text-[16px] leading-[1.9] text-[var(--color-text-secondary)] max-w-[540px] mb-8">
        行きたい場所、日程、好みを伝えるだけ。地元民の知識を学習したAIが、あなただけのオリジナル旅行プランを作成します。
      </p>
      <a
        href="/plan/"
        class="inline-block px-6 py-3 border border-[var(--color-accent)] rounded-[6px] text-[13px] tracking-[0.04em] text-[var(--color-accent)] no-underline hover:opacity-70 transition-opacity duration-300"
      >
        Coming Soon
      </a>
    </div>
  </section>
</BaseLayout>
