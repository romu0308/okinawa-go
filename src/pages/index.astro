---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
import HeroWebGL from '../components/HeroWebGL.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sortedArticles = allArticles.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);

// Build hero data: all articles with their number (by publish date order)
const heroArticles = sortedArticles.map((a, i) => ({
  slug: a.id,
  title: a.data.title,
  description: a.data.description,
  publishedAt: a.data.publishedAt,
  category: a.data.category,
  thumbnail: a.data.thumbnail,
  thumbnailAlt: a.data.thumbnailAlt,
  number: `No.${String(i + 1).padStart(3, '0')}`,
}));

const latestArticles = sortedArticles.slice(0, 5);

const marqueeItems = ['#沖縄旅行', '#地元民', '#沖縄そば', '#穴場', '#2泊3日', '#北谷', '#恩納村', '#グルメ'];
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="OKINAWA!GO!!"
    description="住んでるからこそわかる沖縄がある。沖縄在住フリーランスが、ガイドブックに載らない沖縄の楽しみ方を発信。"
    ogType="website"
  />

  <!-- Hero -->
  <HeroWebGL articles={heroArticles} />

  <!-- Hashtag Marquee -->
  <div class="overflow-hidden py-[11px] border-y" style="border-color: var(--border); border-width: 0.5px;">
    <div class="marquee-track flex whitespace-nowrap" style="width: max-content;">
      {[...marqueeItems, ...marqueeItems, ...marqueeItems, ...marqueeItems].map((tag) => (
        <span class="inline-block px-[18px] py-0 font-['Inter'] text-[11px] text-[#aaa]">{tag}</span>
      ))}
    </div>
  </div>

  <!-- Articles -->
  <section class="px-5 md:px-10 pt-20 md:pt-28 pb-20 md:pb-28 max-w-[1200px] mx-auto">
    <div class="flex items-end justify-between mb-10 reveal">
      <div>
        <span class="label-text block mb-3">Articles</span>
        <h2 class="text-[22px] md:text-[28px] font-medium leading-[1.3] tracking-[-0.02em] text-[var(--text)]">記事一覧</h2>
      </div>
      <a
        href="/articles/"
        class="inline-flex items-center font-['Inter'] text-[10px] text-[#aaa] no-underline hover:text-[var(--text)] transition-colors duration-300 pb-1"
        style="border-bottom: 0.5px solid #ccc;"
      >
        View all
      </a>
    </div>

    <div class="reveal">
      {latestArticles.map((article, i) => (
        <ArticleCard
          slug={article.id}
          title={article.data.title}
          description={article.data.description}
          publishedAt={article.data.publishedAt}
          category={article.data.category}
          thumbnail={article.data.thumbnail}
          thumbnailAlt={article.data.thumbnailAlt}
          number={i + 1}
        />
      ))}
    </div>
  </section>

  <!-- Shindan CTA -->
  <section class="py-16 md:py-24" style="background: var(--dark-bg);">
    <div class="px-5 md:px-10 max-w-[1200px] mx-auto reveal">
      <span class="font-['Inter'] text-[9px] tracking-[0.25em] uppercase block mb-6" style="color: rgba(255,255,255,0.25);">Shindan</span>
      <h2 class="text-[32px] md:text-[40px] font-medium leading-[1.2] tracking-[-0.02em] text-white mb-4">
        あなたの沖縄旅行タイプは？
      </h2>
      <p class="text-[11px] leading-[1.7] mb-10" style="color: rgba(255,255,255,0.35); max-width: 400px;">
        5つの質問に答えるだけで、あなたにぴったりの沖縄旅行スタイルとおすすめエリアがわかります。
      </p>
      <a href="/shindan/" class="inline-flex items-center gap-4 no-underline group">
        <span class="font-['Inter'] text-[13px] tracking-[0.04em] text-white transition-opacity duration-300 group-hover:opacity-60">Start</span>
        <span class="flex items-center justify-center w-8 h-8 rounded-full transition-opacity duration-300 group-hover:opacity-60" style="border: 0.5px solid rgba(255,255,255,0.2);">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2.5 6H9.5M9.5 6L6.5 3M9.5 6L6.5 9" stroke="white" stroke-width="0.8"/></svg>
        </span>
      </a>
    </div>
  </section>

  <!-- AI Trip Planner -->
  <section class="py-16 md:py-24 border-b" style="border-color: var(--border); border-width: 0.5px;">
    <div class="px-5 md:px-10 max-w-[1200px] mx-auto reveal">
      <span class="label-text block mb-6">AI Trip Planner</span>
      <h2 class="text-[22px] md:text-[28px] font-medium leading-[1.3] tracking-[-0.02em] text-[var(--text)] mb-4">
        沖縄在住者AIが、<br class="md:hidden" />あなたの旅をプランニング。
      </h2>
      <p class="font-['Inter'] text-[10px] tracking-[0.12em] text-[var(--text-muted)] mt-6">Coming Soon</p>
    </div>
  </section>
</BaseLayout>
