---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';

const products = [
  {
    title: '沖縄旅行完全プランシート',
    price: '980円',
    description: '沖縄在住5年の地元民が完全監修。カップル・ファミリー・ソロの3パターン対応の旅行プランシート。モデルコース、時間配分、移動手段まですべて網羅。',
    features: ['3パターン（カップル / ファミリー / ソロ）', 'エリア別モデルコース付き', '時間配分・移動手段まで網羅', '印刷してそのまま使えるPDF'],
    href: '/products/plan-sheet/',
    anchor: '#gumroad-plan-sheet',
  },
  {
    title: '沖縄グルメ完全マップ',
    price: '500円',
    description: '地元民が本当に通うお店だけを厳選。エリア別に50店舗をまとめた沖縄グルメの完全ガイド。Googleマップ連携で迷わずたどり着けます。',
    features: ['エリア別おすすめ50選', 'ジャンル別（沖縄そば / 海鮮 / カフェ等）', 'Googleマップ連携リンク付き', '観光客が知らない穴場店も収録'],
    href: '/products/gourmet-map/',
    anchor: '#gumroad-gourmet-map',
  },
  {
    title: '沖縄移住リアルガイド',
    price: '1,980円',
    description: '沖縄に移住して5年。リアルな生活費、仕事事情、住むエリアの選び方、移住前にやるべきことをすべてまとめた電子書籍。',
    features: ['リアルな生活費の内訳', '仕事・転職事情の実態', 'おすすめ居住エリア比較', '移住前チェックリスト付き', '失敗しないための注意点'],
    href: '/products/migration-guide/',
    anchor: '#gumroad-migration-guide',
  },
];
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="デジタルプロダクト"
    description="沖縄在住者が作った旅行プランシート、グルメマップ、移住ガイドなど。沖縄旅行・移住に役立つデジタルコンテンツ。"
  />

  <section class="px-5 md:px-10 pt-16 md:pt-24 pb-20 md:pb-28 max-w-[780px] mx-auto">
    <span class="label-text block mb-3 reveal">Products</span>
    <h1 class="text-[24px] md:text-[32px] font-medium leading-[1.3] tracking-[-0.02em] text-[var(--text)] mb-4 reveal">
      デジタルプロダクト
    </h1>
    <p class="text-[14px] md:text-[16px] leading-[1.8] text-[#666] mb-12 reveal">
      沖縄在住者だからこそ作れる、リアルで実用的なコンテンツを揃えました。
    </p>

    <div class="space-y-8">
      {products.map((product) => (
        <div class="border border-[var(--border)] rounded-lg p-6 md:p-8 reveal">
          <div class="flex items-start justify-between gap-4 mb-3">
            <h2 class="text-[17px] md:text-[19px] font-medium text-[var(--text)]">{product.title}</h2>
            <div class="text-right shrink-0">
              <span class="text-[18px] font-medium text-[var(--text)]">{product.price}</span>
              <span class="block text-[11px] text-[#aaa]">税込</span>
            </div>
          </div>
          <p class="text-[14px] leading-[1.8] text-[#666] mb-4">{product.description}</p>

          <ul class="mb-6 space-y-1.5">
            {product.features.map((f) => (
              <li class="text-[13px] text-[#555] flex items-start gap-2">
                <span class="text-[#d97706] mt-0.5 shrink-0">&#10003;</span>
                <span>{f}</span>
              </li>
            ))}
          </ul>

          <div class="flex items-center gap-3">
            <a
              href={product.href}
              class="inline-block px-6 py-2.5 rounded-full text-[13px] font-medium no-underline transition-all duration-300 bg-[var(--text)] text-white hover:opacity-80"
            >
              詳細を見る
            </a>
            <a
              href={product.anchor}
              class="inline-block px-6 py-2.5 rounded-full text-[13px] font-medium no-underline transition-all duration-300 text-white hover:opacity-90"
              style="background: #d97706;"
            >
              購入する
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
