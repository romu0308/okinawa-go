---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';

const timeline = [
  { year: '2015', title: '新卒でブラック企業に入社', desc: '月残業100時間超え。心身ともにボロボロの日々。' },
  { year: '2017', title: '戦略的転職で年収1.5倍', desc: '市場価値を分析し、スキルの棚卸しを徹底。狙い通りの転職に成功。' },
  { year: '2019', title: '2度目の転職で年収2倍達成', desc: '前職での実績を武器に、年収交渉も成功。理想の環境を手に入れる。' },
  { year: '2021', title: 'フリーランスとして独立', desc: '複数のクライアントワークを確立。場所に縛られない働き方へ。' },
  { year: '2022', title: '沖縄移住・リモートワーク開始', desc: '妻の地元・沖縄へ移住。海が見えるカフェでリモートワークの日々。' },
  { year: '2023', title: 'キャリア孔明メディア開始', desc: '自分の経験を活かし、転職で悩む人を支援するメディアを立ち上げ。' },
];
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="キャリア孔明について"
    description="元ブラック企業社畜から戦略的転職で年収2倍、フリーランスとして沖縄でリモートワーク。キャリア孔明のストーリー。"
  />

  <section class="px-5 md:px-10 pt-16 md:pt-24 pb-20 md:pb-28 max-w-[680px] mx-auto">
    <span class="label-text block mb-3 reveal">About Career Koumei</span>

    <h1 class="text-[24px] md:text-[36px] font-medium leading-[1.3] tracking-[-0.02em] text-[var(--text)] mb-6 reveal">
      キャリア孔明のストーリー
    </h1>

    <p class="text-[14px] md:text-[16px] leading-[1.8] text-[#666] mb-16 reveal">
      元ブラック企業社畜。戦略的転職で年収2倍。<br />
      今はフリーランスとして沖縄でリモートワーク。
    </p>

    <!-- Profile photo placeholder -->
    <div class="aspect-[16/9] bg-[var(--bg-alt)] rounded-lg flex items-center justify-center mb-16 reveal">
      <span class="text-[13px] text-[#ccc]">Profile Photo</span>
    </div>

    <!-- Mission -->
    <div class="mb-16 reveal">
      <span class="label-text block mb-4">Mission</span>
      <blockquote class="border-l border-[var(--border)] pl-5 py-2">
        <p class="text-[17px] md:text-[20px] font-medium leading-[1.6] text-[var(--text)] !mb-0">
          一人でも多くの人を、<br />理不尽な労働環境から解放する。
        </p>
      </blockquote>
      <p class="text-[14px] md:text-[16px] leading-[1.8] text-[#666] mt-6">
        「我慢するのが仕事」「石の上にも三年」。そんな言葉に縛られて、心も体も壊しかけた過去がある。
        だからこそ、転職は「逃げ」じゃなく「戦略」だと伝えたい。正しい情報と戦略があれば、誰でもキャリアは変えられる。
      </p>
    </div>

    <!-- Profile details -->
    <div class="mb-16 reveal">
      <span class="label-text block mb-4">Profile</span>
      <ul class="space-y-3">
        <li class="flex items-start gap-6 py-3 border-t" style="border-color: var(--border); border-width: 0.5px;">
          <span class="font-['Inter'] text-[9px] tracking-[0.12em] text-[#aaa] uppercase shrink-0 pt-[2px] w-20">Name</span>
          <span class="text-[14px] text-[var(--text)]">キャリア孔明 / KOUMEI</span>
        </li>
        <li class="flex items-start gap-6 py-3 border-t" style="border-color: var(--border); border-width: 0.5px;">
          <span class="font-['Inter'] text-[9px] tracking-[0.12em] text-[#aaa] uppercase shrink-0 pt-[2px] w-20">Base</span>
          <span class="text-[14px] text-[var(--text)]">沖縄県（リモートワーク）</span>
        </li>
        <li class="flex items-start gap-6 py-3 border-t" style="border-color: var(--border); border-width: 0.5px;">
          <span class="font-['Inter'] text-[9px] tracking-[0.12em] text-[#aaa] uppercase shrink-0 pt-[2px] w-20">Work</span>
          <span class="text-[14px] text-[var(--text)]">フリーランス / メディア運営</span>
        </li>
        <li class="flex items-start gap-6 py-3 border-t" style="border-color: var(--border); border-width: 0.5px;">
          <span class="font-['Inter'] text-[9px] tracking-[0.12em] text-[#aaa] uppercase shrink-0 pt-[2px] w-20">X</span>
          <a href="https://x.com/KOUMEI_GO" target="_blank" rel="noopener noreferrer" class="text-[14px] text-[var(--text)] no-underline hover:opacity-60 transition-opacity duration-300">@KOUMEI_GO</a>
        </li>
        <li class="flex items-start gap-6 py-3 border-t" style="border-color: var(--border); border-width: 0.5px;">
          <span class="font-['Inter'] text-[9px] tracking-[0.12em] text-[#aaa] uppercase shrink-0 pt-[2px] w-20">LINE</span>
          <a href="/line/" class="text-[14px] text-[var(--text)] no-underline hover:opacity-60 transition-opacity duration-300">友達追加はこちら</a>
        </li>
      </ul>
    </div>

    <!-- Timeline -->
    <div class="reveal">
      <span class="label-text block mb-6">Timeline</span>
      <div class="space-y-0">
        {timeline.map((item, i) => (
          <div class="flex gap-5 pb-8 relative">
            {/* Line */}
            {i < timeline.length - 1 && (
              <div class="absolute left-[15px] top-[28px] bottom-0 w-[1px] bg-[var(--border)]"></div>
            )}
            {/* Dot */}
            <div class="w-[31px] shrink-0 flex justify-center pt-[6px]">
              <div class="w-[7px] h-[7px] rounded-full bg-[var(--text)] relative z-10"></div>
            </div>
            <div>
              <span class="font-['Inter'] text-[11px] tracking-[0.08em] text-[#aaa] block mb-1">{item.year}</span>
              <h3 class="text-[15px] font-medium text-[var(--text)] mb-1">{item.title}</h3>
              <p class="text-[13px] leading-[1.7] text-[#888] !mb-0">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
