---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="404 Not Found"
    description="ページが見つかりませんでした。"
  />

  <section class="px-5 md:px-10 pt-24 md:pt-32 pb-24 md:pb-32 max-w-[680px] mx-auto">
    <span class="label-text block mb-3 reveal">404</span>
    <h1 class="text-[28px] md:text-[40px] font-medium leading-[1.2] tracking-[-0.02em] text-[var(--text)] mb-6 reveal">
      ページが見つかりません
    </h1>
    <p class="text-[14px] leading-[1.8] text-[var(--text-secondary)] mb-10 reveal">
      お探しのページは存在しないか、移動した可能性があります。
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-3 font-['Inter'] text-[10px] tracking-[0.08em] text-[var(--text-secondary)] no-underline hover:text-[var(--text)] transition-colors duration-300 reveal"
    >
      ← Back
    </a>
  </section>
</BaseLayout>
