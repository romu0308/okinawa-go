---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';

const campaigns = [
  { slug: 'summer2026', title: '2026夏、沖縄の正しい楽しみ方', period: '2026年6月〜9月', active: true },
];
---
<BaseLayout>
  <SEOHead slot="head" title="キャンペーン | OKINAWA!GO!!" description="OKINAWA!GO!!の期間限定キャンペーン" />
  <section class="px-5 md:px-10 pt-16 md:pt-24 pb-20 md:pb-28 max-w-[680px] mx-auto">
    <span class="label-text block mb-3 reveal">Campaigns</span>
    <h1 class="text-[28px] md:text-[36px] font-medium leading-[1.2] mb-12 reveal">キャンペーン</h1>
    {campaigns.map(c => (
      <a href={`/campaign/${c.slug}/`} class="block p-6 rounded-lg no-underline group mb-4 reveal" style="border: 0.5px solid var(--border);">
        {c.active && <span class="inline-block px-2 py-0.5 text-[10px] font-medium bg-green-100 text-green-700 rounded mb-2">開催中</span>}
        <h2 class="text-[18px] font-medium group-hover:opacity-60 transition-opacity">{c.title}</h2>
        <p class="text-[12px] text-[var(--text-secondary)] mt-1">{c.period}</p>
      </a>
    ))}
  </section>
</BaseLayout>
