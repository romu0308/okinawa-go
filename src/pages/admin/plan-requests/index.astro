---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';

const fs = await import('node:fs');
const path = await import('node:path');
const filePath = path.join(process.cwd(), 'src/data/plan-requests.json');

let requests: any[] = [];
try {
  requests = JSON.parse(fs.readFileSync(filePath, 'utf-8'));
} catch {}

// Sort by newest first
requests.sort((a: any, b: any) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());

const statusLabels: Record<string, { text: string; color: string }> = {
  new: { text: '新規', color: 'bg-blue-100 text-blue-700' },
  'in-progress': { text: '対応中', color: 'bg-yellow-100 text-yellow-700' },
  done: { text: '完了', color: 'bg-green-100 text-green-700' },
};
---

<AdminLayout title="プラン作成リクエスト">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-bold text-gray-900">プラン作成リクエスト</h1>
    <span class="text-sm text-gray-500">{requests.length}件</span>
  </div>

  {requests.length === 0 ? (
    <div class="bg-white rounded-lg border border-gray-200 p-12 text-center">
      <p class="text-gray-500 text-sm">リクエストはまだありません</p>
    </div>
  ) : (
    <div class="space-y-4">
      {requests.map((req: any) => {
        const status = statusLabels[req.status] || statusLabels.new;
        return (
          <div class="bg-white rounded-lg border border-gray-200 p-5" data-id={req.id}>
            <div class="flex items-start justify-between gap-4 mb-3">
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-sm font-medium text-gray-900">{req.name}</span>
                  <span class:list={["text-[11px] px-2 py-0.5 rounded-full font-medium", status.color]}>
                    {status.text}
                  </span>
                </div>
                <p class="text-xs text-gray-500">{req.email}</p>
              </div>
              <div class="text-right shrink-0">
                <p class="text-xs text-gray-400">{new Date(req.created_at).toLocaleDateString('ja-JP')}</p>
                <p class="text-xs text-gray-400">#{req.id}</p>
              </div>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-3 text-xs">
              <div>
                <span class="text-gray-400">日数:</span>
                <span class="text-gray-700 ml-1">{req.days}</span>
              </div>
              <div>
                <span class="text-gray-400">人数:</span>
                <span class="text-gray-700 ml-1">{req.group}</span>
              </div>
              <div>
                <span class="text-gray-400">予算:</span>
                <span class="text-gray-700 ml-1">{req.budget || '未記入'}</span>
              </div>
              <div>
                <span class="text-gray-400">時期:</span>
                <span class="text-gray-700 ml-1">{req.period}</span>
              </div>
            </div>
            {req.interests && req.interests.length > 0 && (
              <div class="flex flex-wrap gap-1 mb-3">
                {req.interests.map((interest: string) => (
                  <span class="text-[11px] px-2 py-0.5 bg-gray-100 text-gray-600 rounded">{interest}</span>
                ))}
              </div>
            )}
            {req.notes && (
              <p class="text-xs text-gray-600 bg-gray-50 rounded p-3 mb-3">{req.notes}</p>
            )}
            <div class="flex items-center gap-2">
              <select
                class="status-select text-xs border border-gray-200 rounded px-2 py-1.5 bg-white text-gray-700 outline-none"
                data-id={req.id}
              >
                <option value="new" selected={req.status === 'new'}>新規</option>
                <option value="in-progress" selected={req.status === 'in-progress'}>対応中</option>
                <option value="done" selected={req.status === 'done'}>完了</option>
              </select>
              <button
                class="update-status text-xs px-3 py-1.5 bg-gray-900 text-white rounded hover:bg-gray-700 transition-colors"
                data-id={req.id}
              >
                更新
              </button>
            </div>
          </div>
        );
      })}
    </div>
  )}

  <script is:inline>
    document.querySelectorAll('.update-status').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id;
        const select = document.querySelector(`.status-select[data-id="${id}"]`);
        const newStatus = select.value;
        try {
          const res = await fetch('/api/plan-request', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ _action: 'update-status', id: Number(id), status: newStatus }),
          });
          if (res.ok) {
            window.location.reload();
          }
        } catch {
          alert('更新に失敗しました');
        }
      });
    });
  </script>
</AdminLayout>
