---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';

const fs = await import('node:fs');
const path = await import('node:path');
const filePath = path.join(process.cwd(), 'src/data/business-inquiries.json');

let inquiries: any[] = [];
try {
  inquiries = JSON.parse(fs.readFileSync(filePath, 'utf-8'));
} catch {}

// Sort by newest first
inquiries.sort((a: any, b: any) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime());

const statusLabels: Record<string, { text: string; color: string }> = {
  new: { text: '新規', color: 'bg-blue-100 text-blue-700' },
  'in-progress': { text: '対応中', color: 'bg-yellow-100 text-yellow-700' },
  done: { text: '完了', color: 'bg-green-100 text-green-700' },
};
---

<AdminLayout title="法人お問い合わせ">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-bold text-gray-900">法人お問い合わせ</h1>
    <span class="text-sm text-gray-500">{inquiries.length}件</span>
  </div>

  {inquiries.length === 0 ? (
    <div class="bg-white rounded-lg border border-gray-200 p-12 text-center">
      <p class="text-gray-500 text-sm">お問い合わせはまだありません</p>
    </div>
  ) : (
    <div class="space-y-4">
      {inquiries.map((inq: any) => {
        const status = statusLabels[inq.status] || statusLabels.new;
        return (
          <div class="bg-white rounded-lg border border-gray-200 p-5" data-id={inq.id}>
            <div class="flex items-start justify-between gap-4 mb-3">
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-sm font-medium text-gray-900">{inq.company}</span>
                  <span class:list={["text-[11px] px-2 py-0.5 rounded-full font-medium", status.color]}>
                    {status.text}
                  </span>
                </div>
                <p class="text-xs text-gray-500">{inq.name} / {inq.email}{inq.phone ? ` / ${inq.phone}` : ''}</p>
              </div>
              <div class="text-right shrink-0">
                <p class="text-xs text-gray-400">{new Date(inq.created_at).toLocaleDateString('ja-JP')}</p>
                <p class="text-xs text-gray-400">#{inq.id}</p>
              </div>
            </div>
            {inq.service_interest && inq.service_interest.length > 0 && (
              <div class="flex flex-wrap gap-1 mb-3">
                {inq.service_interest.map((s: string) => (
                  <span class="text-[11px] px-2 py-0.5 bg-gray-100 text-gray-600 rounded">{s}</span>
                ))}
              </div>
            )}
            {inq.message && (
              <p class="text-xs text-gray-600 bg-gray-50 rounded p-3 mb-3 whitespace-pre-wrap">{inq.message}</p>
            )}
            <div class="flex items-center gap-2">
              <select
                class="status-select text-xs border border-gray-200 rounded px-2 py-1.5 bg-white text-gray-700 outline-none"
                data-id={inq.id}
              >
                <option value="new" selected={inq.status === 'new'}>新規</option>
                <option value="in-progress" selected={inq.status === 'in-progress'}>対応中</option>
                <option value="done" selected={inq.status === 'done'}>完了</option>
              </select>
              <button
                class="update-status text-xs px-3 py-1.5 bg-gray-900 text-white rounded hover:bg-gray-700 transition-colors"
                data-id={inq.id}
              >
                更新
              </button>
            </div>
          </div>
        );
      })}
    </div>
  )}

  <script is:inline>
    document.querySelectorAll('.update-status').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id;
        const select = document.querySelector(`.status-select[data-id="${id}"]`);
        const newStatus = select.value;
        try {
          const res = await fetch('/api/business/inquiry', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ _action: 'update-status', id: Number(id), status: newStatus }),
          });
          if (res.ok) {
            window.location.reload();
          }
        } catch {
          alert('更新に失敗しました');
        }
      });
    });
  </script>
</AdminLayout>
