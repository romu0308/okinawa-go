---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import CTABox from '../../components/CTABox.astro';
import ArticleCardGrid from '../../components/ArticleCardGrid.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content, headings } = await render(article);

const categoryLabels: Record<string, string> = {
  'model-course': 'Model Course',
  'area-guide': 'Area Guide',
  'food': 'Food',
  'activity': 'Activity',
  'tips': 'Tips',
  'seasonal': 'Seasonal',
};

const formatDate = (dateStr: string) => {
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
};

// Table of Contents (h2, h3)
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

// Related articles
const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const relatedArticles = allArticles
  .filter((a) => a.id !== article.id)
  .filter((a) => a.data.category === article.data.category || a.data.area === article.data.area)
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 3);
---

<BaseLayout>
  <SEOHead
    slot="head"
    title={article.data.title}
    description={article.data.description}
    ogImage={article.data.thumbnail}
    ogType="article"
    publishedAt={article.data.publishedAt}
    updatedAt={article.data.updatedAt}
    isArticle={true}
  />

  <article class="px-6 md:px-12 pt-10 md:pt-16 pb-20 md:pb-28 max-w-[780px] mx-auto">
    <!-- Breadcrumb -->
    <nav class="mb-8">
      <ol class="flex items-center gap-2 meta-text text-[var(--color-text-tertiary)]">
        <li><a href="/" class="no-underline hover:text-[var(--color-text-primary)] transition-colors duration-300">Home</a></li>
        <li>/</li>
        <li><a href="/articles/" class="no-underline hover:text-[var(--color-text-primary)] transition-colors duration-300">Articles</a></li>
        <li>/</li>
        <li class="text-[var(--color-text-secondary)] truncate max-w-[200px]">{article.data.title}</li>
      </ol>
    </nav>

    <!-- Category + Date -->
    <div class="flex items-center gap-3 mb-5">
      <span class="meta-text text-[var(--color-accent)]">
        {categoryLabels[article.data.category] || article.data.category}
      </span>
      <span class="meta-text text-[var(--color-text-tertiary)]">
        {formatDate(article.data.publishedAt)}
      </span>
    </div>

    <!-- Title -->
    <h1 class="text-[24px] md:text-[32px] font-medium leading-[1.3] tracking-[-0.01em] text-[var(--color-text-primary)] mb-8">
      {article.data.title}
    </h1>

    <!-- Thumbnail placeholder -->
    <div class="w-full aspect-[16/9] rounded-[6px] overflow-hidden bg-gradient-to-br from-[#1A6B7A] via-[#2A8B9A] to-[#E1F0F2] mb-12">
      {article.data.thumbnail && (
        <img
          src={article.data.thumbnail}
          alt={article.data.thumbnailAlt}
          class="w-full h-full object-cover"
          loading="eager"
        />
      )}
    </div>

    <!-- Table of Contents -->
    {toc.length > 0 && (
      <nav class="border border-[var(--color-border)] rounded-[6px] px-6 py-6 mb-12">
        <p class="meta-text text-[var(--color-text-tertiary)] mb-4">Contents</p>
        <ul class="space-y-2">
          {toc.map((heading) => (
            <li class:list={[heading.depth === 3 && 'pl-4']}>
              <a
                href={`#${heading.slug}`}
                class="text-[14px] leading-[1.7] text-[var(--color-text-secondary)] no-underline hover:text-[var(--color-accent)] transition-colors duration-300"
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    )}

    <!-- Article Body -->
    <div class="prose max-w-none">
      <Content />
    </div>

    <!-- CTA Box -->
    <CTABox />
  </article>

  <!-- Related Articles -->
  {relatedArticles.length > 0 && (
    <section class="px-6 md:px-12 pb-20 md:pb-28 max-w-[1200px] mx-auto border-t border-[var(--color-border)] pt-16">
      <p class="meta-text text-[var(--color-text-tertiary)] mb-10">Related Articles</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-x-6 gap-y-10">
        {relatedArticles.map((related) => (
          <ArticleCardGrid
            slug={related.id}
            title={related.data.title}
            description={related.data.description}
            publishedAt={related.data.publishedAt}
            category={related.data.category}
            thumbnail={related.data.thumbnail}
            thumbnailAlt={related.data.thumbnailAlt}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
