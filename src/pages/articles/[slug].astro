---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import CTABox from '../../components/CTABox.astro';
import AffiliateBox from '../../components/AffiliateBox.astro';
import AdSlot from '../../components/AdSlot.astro';
import AffiliateSidebar from '../../components/AffiliateSidebar.astro';
import ArticleCardGrid from '../../components/ArticleCardGrid.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content, headings } = await render(article);

const areaLabels: Record<string, string> = {
  'naha': '那覇',
  'chatan': '北谷',
  'nago': '名護',
  'onna': '恩納村',
  'itoman': '糸満',
  'churaumi': '美ら海',
  'nanjo': '南城',
  'ginowan': '宜野湾',
  'okinawa-city': '沖縄市',
  'yomitan': '読谷',
  'miyako': '宮古島',
  'ishigaki': '石垣島',
  'kerama': '慶良間',
  'north': '北部',
  'central': '中部',
  'south': '南部',
};

const categoryLabels: Record<string, string> = {
  'model-course': 'Model Course',
  'area-guide': 'Area Guide',
  'food': 'Food',
  'activity': 'Activity',
  'tips': 'Tips',
  'seasonal': 'Seasonal',
};

const formatDate = (dateStr: string) => {
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
};

const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

// Calculate reading time (Japanese: ~600 chars/min)
const readingTime = Math.max(1, Math.ceil((article.body?.length || 1000) / 600));

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const relatedArticles = allArticles
  .filter((a) => a.id !== article.id)
  .filter((a) => a.data.category === article.data.category || a.data.area === article.data.area)
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 3);

// Determine affiliate boxes by category
const category = article.data.category;
const affiliateTypes: ('hotel' | 'activity' | 'car' | 'flight' | 'wifi' | 'card')[] = (() => {
  switch (category) {
    case 'model-course': return ['hotel', 'car', 'activity'];
    case 'area-guide': return ['hotel', 'activity'];
    case 'food': return ['hotel'];
    case 'activity': return ['activity'];
    case 'tips': return ['car'];
    case 'seasonal': return ['hotel', 'flight'];
    default: return ['hotel'];
  }
})();

const areaLabel = article.data.area ? areaLabels[article.data.area] : undefined;
---

<BaseLayout>
  <SEOHead
    slot="head"
    title={article.data.title}
    description={article.data.description}
    ogImage={article.data.thumbnail}
    ogType="article"
    publishedAt={article.data.publishedAt}
    updatedAt={article.data.updatedAt}
    isArticle={true}
  />

  <article>
    <!-- Header area -->
    <div class="px-5 md:px-10 pt-8 md:pt-12 max-w-[680px] mx-auto">
      <!-- Breadcrumb -->
      <nav class="mb-8 reveal">
        <ol class="flex items-center gap-2 font-['Inter'] text-[9px] tracking-[0.12em] uppercase text-[var(--text-tertiary)]">
          <li><a href="/" class="no-underline hover:text-[var(--text)] transition-colors duration-300">Home</a></li>
          <li>/</li>
          <li><a href="/articles/" class="no-underline hover:text-[var(--text)] transition-colors duration-300">Articles</a></li>
        </ol>
      </nav>

      <!-- Category + Date -->
      <div class="flex items-center gap-3 mb-5 reveal">
        <span class="meta-text">
          {categoryLabels[article.data.category] || article.data.category}
        </span>
        <span class="font-['Inter'] text-[9px] tracking-[0.12em] text-[var(--text-muted)]">
          {formatDate(article.data.publishedAt)}
        </span>
        <span class="font-['Inter'] text-[9px] tracking-[0.12em] text-[var(--text-muted)]">
          {readingTime} min read
        </span>
      </div>

      <!-- Title -->
      <h1 class="text-[28px] md:text-[36px] font-medium leading-[1.3] tracking-[-0.02em] text-[var(--text)] mb-10 reveal">
        {article.data.title}
      </h1>
    </div>

    <!-- Eyecatch - full width, no border-radius -->
    <div class="w-full overflow-hidden mb-12 reveal" style="height: 300px; max-height: 50vh;">
      {article.data.thumbnail ? (
        <img
          src={article.data.thumbnail}
          alt={article.data.thumbnailAlt}
          class="w-full h-full object-cover"
          loading="eager"
        />
      ) : (
        <div class="w-full h-full bg-gradient-to-br from-[#ddd] to-[#eee]"></div>
      )}
    </div>

    <!-- Ad slot after eyecatch -->
    <div class="px-5 md:px-10 max-w-[680px] mx-auto">
      <AdSlot position="top" />
    </div>

    <!-- Content area with sidebar -->
    <div class="flex gap-10 justify-center px-5 md:px-10">
      <!-- Main content -->
      <div class="max-w-[680px] w-full pb-16 md:pb-24">
        <!-- Table of Contents -->
        {toc.length > 0 && (
          <nav class="mb-12 pl-5 reveal" style="border-left: 1px solid var(--border);">
            <p class="label-text mb-4">Contents</p>
            <ul class="space-y-2">
              {toc.map((heading) => (
                <li class:list={[heading.depth === 3 && 'pl-4']}>
                  <a
                    href={`#${heading.slug}`}
                    class="text-[13px] leading-[1.7] text-[var(--text-secondary)] no-underline hover:text-[var(--text)] transition-colors duration-300"
                  >
                    {heading.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        )}

        <!-- Article Body -->
        <div class="prose max-w-none reveal">
          <Content />
        </div>

        <!-- Share -->
        <div class="mt-12 mb-8 pt-8 border-t" style="border-color: var(--border);">
          <p class="label-text mb-4">Share</p>
          <div class="flex items-center gap-6">
            <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(article.data.title)}&url=${encodeURIComponent(`https://okinawa-go.jp/articles/${article.id}/`)}&hashtags=沖縄旅行,OKINAWAGO`}
               target="_blank" rel="noopener"
               class="text-[12px] text-[var(--text-secondary)] no-underline hover:text-[var(--text)] transition-colors">
              X (Twitter)
            </a>
            <a href={`https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(`https://okinawa-go.jp/articles/${article.id}/`)}`}
               target="_blank" rel="noopener"
               class="text-[12px] text-[var(--text-secondary)] no-underline hover:text-[var(--text)] transition-colors">
              LINE
            </a>
            <button id="copy-link"
               class="text-[12px] text-[var(--text-secondary)] hover:text-[var(--text)] transition-colors bg-transparent border-none cursor-pointer">
              Copy Link
            </button>
          </div>
        </div>

        <!-- Author -->
        <div class="mt-8 mb-12 p-6 rounded-lg" style="background: var(--bg-alt);">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-[var(--text)] flex items-center justify-center text-white text-[14px] font-medium shrink-0">K</div>
            <div>
              <p class="text-[14px] font-medium mb-1">KOUMEI</p>
              <p class="text-[12px] text-[var(--text-secondary)] leading-[1.7]">
                沖縄在住5年。妻は沖縄出身。関西人。ガイドブックに載らない沖縄の楽しみ方を発信中。
              </p>
              <a href="https://twitter.com/KOUMEI_GO" target="_blank" rel="noopener"
                class="inline-block mt-2 text-[11px] text-[var(--text-tertiary)] no-underline hover:text-[var(--text)] transition-colors">
                @KOUMEI_GO
              </a>
            </div>
          </div>
        </div>

        <!-- Category-appropriate Affiliate Boxes -->
        {affiliateTypes.map((aType) => (
          <AffiliateBox type={aType} spotName={areaLabel} area={article.data.area} />
        ))}

        <!-- CTA Box -->
        <CTABox />

        <!-- Ad slot after CTA -->
        <AdSlot position="bottom" />
      </div>

      <!-- Sidebar for desktop -->
      <AffiliateSidebar area={article.data.area} />
    </div>
  </article>

  <!-- Related Articles -->
  {relatedArticles.length > 0 && (
    <section class="px-5 md:px-10 pb-20 md:pb-28 pt-16 max-w-[1200px] mx-auto border-t" style="border-color: var(--border); border-width: 0.5px;">
      <div class="reveal">
        <span class="label-text block mb-3">Related</span>
        <h2 class="text-[22px] md:text-[28px] font-medium leading-[1.3] tracking-[-0.02em] text-[var(--text)] mb-10">関連記事</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-x-6 gap-y-10 reveal">
        {relatedArticles.map((related, i) => (
          <ArticleCardGrid
            slug={related.id}
            title={related.data.title}
            description={related.data.description}
            publishedAt={related.data.publishedAt}
            category={related.data.category}
            thumbnail={related.data.thumbnail}
            thumbnailAlt={related.data.thumbnailAlt}
            number={i + 1}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<script>
  document.getElementById('copy-link')?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(window.location.href);
    const btn = document.getElementById('copy-link');
    if (btn) { btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy Link', 2000); }
  });
</script>
