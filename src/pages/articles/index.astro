---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sortedArticles = allArticles.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);

const categories = [
  { value: 'all', label: 'All' },
  { value: 'model-course', label: 'Model Course' },
  { value: 'area-guide', label: 'Area Guide' },
  { value: 'food', label: 'Food' },
  { value: 'activity', label: 'Activity' },
  { value: 'tips', label: 'Tips' },
  { value: 'seasonal', label: 'Seasonal' },
];
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="記事一覧"
    description="沖縄在住者が発信する、ガイドブックに載らない沖縄の旅行情報。モデルコース、エリアガイド、グルメ、旅行Tipsなど。"
  />

  <section class="px-5 md:px-10 pt-16 md:pt-24 pb-20 md:pb-28 max-w-[1200px] mx-auto">
    <div class="mb-12 reveal">
      <span class="label-text block mb-3">Articles</span>
      <h1 class="text-[22px] md:text-[28px] font-medium leading-[1.3] tracking-[-0.02em] text-[var(--text)]">
        記事一覧
      </h1>
    </div>

    <!-- Category Filter -->
    <div class="flex flex-wrap gap-2 mb-12 reveal" id="category-filter">
      {categories.map((cat) => (
        <button
          data-category={cat.value}
          class="filter-btn px-4 py-2 rounded-[4px] font-['Inter'] text-[10px] tracking-[0.08em] uppercase transition-all duration-300 cursor-pointer bg-transparent"
          style="border: 0.5px solid var(--border); color: var(--text-secondary);"
        >
          {cat.label}
        </button>
      ))}
    </div>

    <!-- Articles -->
    <div id="articles-list" class="reveal">
      {sortedArticles.map((article, i) => (
        <div data-article-category={article.data.category}>
          <ArticleCard
            slug={article.id}
            title={article.data.title}
            description={article.data.description}
            publishedAt={article.data.publishedAt}
            category={article.data.category}
            thumbnail={article.data.thumbnail}
            thumbnailAlt={article.data.thumbnailAlt}
            number={i + 1}
          />
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const articles = document.querySelectorAll('[data-article-category]');

  function setActiveCategory(category: string) {
    buttons.forEach((btn) => {
      const el = btn as HTMLElement;
      const btnCat = btn.getAttribute('data-category');
      if (btnCat === category) {
        el.style.borderColor = 'var(--text)';
        el.style.color = 'var(--text)';
      } else {
        el.style.borderColor = 'var(--border)';
        el.style.color = 'var(--text-secondary)';
      }
    });

    articles.forEach((article) => {
      const el = article as HTMLElement;
      if (category === 'all' || article.getAttribute('data-article-category') === category) {
        el.style.display = '';
      } else {
        el.style.display = 'none';
      }
    });
  }

  const params = new URLSearchParams(window.location.search);
  const initialCategory = params.get('category') || 'all';
  setActiveCategory(initialCategory);

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = btn.getAttribute('data-category') || 'all';
      setActiveCategory(category);
      const url = new URL(window.location.href);
      if (category === 'all') {
        url.searchParams.delete('category');
      } else {
        url.searchParams.set('category', category);
      }
      window.history.replaceState({}, '', url.toString());
    });
  });
</script>
