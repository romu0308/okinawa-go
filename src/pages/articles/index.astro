---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import ArticleCardGrid from '../../components/ArticleCardGrid.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sortedArticles = allArticles.sort(
  (a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime()
);

const categories = [
  { value: 'all', label: 'All' },
  { value: 'model-course', label: 'Model Course' },
  { value: 'area-guide', label: 'Area Guide' },
  { value: 'food', label: 'Food' },
  { value: 'activity', label: 'Activity' },
  { value: 'tips', label: 'Tips' },
  { value: 'seasonal', label: 'Seasonal' },
];
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="記事一覧"
    description="沖縄在住者が発信する、ガイドブックに載らない沖縄の旅行情報。モデルコース、エリアガイド、グルメ、旅行Tipsなど。"
  />

  <section class="px-6 md:px-12 pt-16 md:pt-24 pb-20 md:pb-28 max-w-[1200px] mx-auto">
    <p class="meta-text text-[var(--color-text-tertiary)] mb-4">Articles</p>
    <h1 class="text-[28px] md:text-[32px] font-medium leading-[1.3] tracking-[-0.01em] text-[var(--color-text-primary)] mb-12">
      記事一覧
    </h1>

    <!-- Category Filter -->
    <div class="flex flex-wrap gap-2 mb-12" id="category-filter">
      {categories.map((cat) => (
        <button
          data-category={cat.value}
          class:list={[
            'filter-btn px-4 py-2 rounded-[6px] text-[12px] tracking-[0.06em] uppercase transition-colors duration-300 border cursor-pointer',
            'border-[var(--color-border)] text-[var(--color-text-secondary)] bg-transparent hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]',
          ]}
        >
          {cat.label}
        </button>
      ))}
    </div>

    <!-- Articles Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-10" id="articles-grid">
      {sortedArticles.map((article) => (
        <div data-article-category={article.data.category}>
          <ArticleCardGrid
            slug={article.id}
            title={article.data.title}
            description={article.data.description}
            publishedAt={article.data.publishedAt}
            category={article.data.category}
            thumbnail={article.data.thumbnail}
            thumbnailAlt={article.data.thumbnailAlt}
          />
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const articles = document.querySelectorAll('[data-article-category]');

  function setActiveCategory(category: string) {
    buttons.forEach((btn) => {
      const btnCat = btn.getAttribute('data-category');
      if (btnCat === category) {
        btn.classList.remove('border-[var(--color-border)]', 'text-[var(--color-text-secondary)]', 'bg-transparent');
        btn.classList.add('border-[var(--color-accent)]', 'text-[var(--color-accent)]', 'bg-[var(--color-accent-light)]');
      } else {
        btn.classList.add('border-[var(--color-border)]', 'text-[var(--color-text-secondary)]', 'bg-transparent');
        btn.classList.remove('border-[var(--color-accent)]', 'text-[var(--color-accent)]', 'bg-[var(--color-accent-light)]');
      }
    });

    articles.forEach((article) => {
      const el = article as HTMLElement;
      if (category === 'all' || article.getAttribute('data-article-category') === category) {
        el.style.display = '';
      } else {
        el.style.display = 'none';
      }
    });
  }

  // Initialize from URL param
  const params = new URLSearchParams(window.location.search);
  const initialCategory = params.get('category') || 'all';
  setActiveCategory(initialCategory);

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = btn.getAttribute('data-category') || 'all';
      setActiveCategory(category);
      const url = new URL(window.location.href);
      if (category === 'all') {
        url.searchParams.delete('category');
      } else {
        url.searchParams.set('category', category);
      }
      window.history.replaceState({}, '', url.toString());
    });
  });
</script>
