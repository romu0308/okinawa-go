---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import AffiliateBox from '../../components/AffiliateBox.astro';
import ArticleCardGrid from '../../components/ArticleCardGrid.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const spots = await getCollection('spots');
  return spots.map((spot) => ({
    params: { slug: spot.id },
    props: { spot },
  }));
}

const { spot } = Astro.props;
const { Content } = await render(spot);

const categoryLabels: Record<string, string> = {
  restaurant: 'レストラン',
  cafe: 'カフェ',
  beach: 'ビーチ',
  activity: 'アクティビティ',
  hotel: 'ホテル',
  shopping: 'ショッピング',
  cultural: '文化・観光',
};

const categoryEngLabels: Record<string, string> = {
  restaurant: 'Restaurant',
  cafe: 'Cafe',
  beach: 'Beach',
  activity: 'Activity',
  hotel: 'Hotel',
  shopping: 'Shopping',
  cultural: 'Cultural',
};

const areaLabels: Record<string, string> = {
  naha: '那覇',
  chatan: '北谷',
  yomitan: '読谷',
  onna: '恩納',
  nago: '名護',
  motobu: '本部',
  south: '南部',
  island: '離島',
};

// Google Maps embed URL from address
const mapQuery = encodeURIComponent(`沖縄県${spot.data.address}`);
const mapEmbedUrl = `https://maps.google.com/maps?q=${mapQuery}&t=m&z=15&output=embed&iwloc=near`;
const mapLinkUrl = `https://www.google.com/maps/search/?api=1&query=${mapQuery}`;

// Info items for the detail table
const infoItems: { label: string; value: string | undefined }[] = [
  { label: '住所', value: `沖縄県${spot.data.address}` },
  { label: '電話', value: spot.data.phone },
  { label: '営業時間', value: spot.data.hours },
  { label: '定休日', value: spot.data.closed },
  { label: '予算', value: spot.data.budget },
  { label: '駐車場', value: spot.data.parking },
];

// Related articles (same area)
const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const relatedArticles = allArticles
  .filter((a) => a.data.area === spot.data.area)
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 3);

// Related spots (same category or area, excluding current)
const allSpots = await getCollection('spots');
const relatedSpots = allSpots
  .filter((s) => s.id !== spot.id)
  .filter((s) => s.data.category === spot.data.category || s.data.area === spot.data.area)
  .slice(0, 6);
---

<BaseLayout>
  <SEOHead
    slot="head"
    title={`${spot.data.name} - ${categoryLabels[spot.data.category]}`}
    description={spot.data.description}
    ogImage={spot.data.image}
  />

  <article>
    <!-- Header -->
    <div class="px-5 md:px-10 pt-8 md:pt-12 max-w-[680px] mx-auto">
      <!-- Breadcrumb -->
      <nav class="mb-8 reveal">
        <ol class="flex items-center gap-2 font-['Inter'] text-[9px] tracking-[0.12em] uppercase text-[var(--text-tertiary)]">
          <li><a href="/" class="no-underline hover:text-[var(--text)] transition-colors duration-300">Home</a></li>
          <li>/</li>
          <li><a href="/spots/" class="no-underline hover:text-[var(--text)] transition-colors duration-300">Spots</a></li>
          <li>/</li>
          <li>{categoryEngLabels[spot.data.category]}</li>
        </ol>
      </nav>

      <!-- Category + Area -->
      <div class="flex items-center gap-3 mb-5 reveal">
        <span class="meta-text">
          {categoryEngLabels[spot.data.category]}
        </span>
        <span class="text-[10px] text-[var(--text-tertiary)]">
          {areaLabels[spot.data.area]}エリア
        </span>
        {spot.data.recommended && (
          <span class="font-['Inter'] text-[9px] tracking-[0.12em] px-2 py-[2px] rounded-[2px] text-white" style="background: #333;">
            RECOMMENDED
          </span>
        )}
      </div>

      <!-- Name -->
      <h1 class="text-[28px] md:text-[36px] font-medium leading-[1.3] tracking-[-0.02em] text-[var(--text)] mb-10 reveal">
        {spot.data.name}
      </h1>
    </div>

    <!-- Eyecatch -->
    <div class="w-full overflow-hidden mb-12 reveal" style="height: 300px; max-height: 50vh;">
      <img
        src={spot.data.image}
        alt={spot.data.name}
        class="w-full h-full object-cover"
        loading="eager"
      />
    </div>

    <!-- Content -->
    <div class="px-5 md:px-10 max-w-[680px] mx-auto pb-16 md:pb-24">
      <!-- Description -->
      <div class="prose max-w-none mb-10 reveal">
        <Content />
      </div>

      <!-- Info Table -->
      <div class="mb-10 reveal">
        <p class="label-text mb-4">Information</p>
        <div class="rounded-lg overflow-hidden" style="border: 0.5px solid var(--border);">
          {infoItems.map((item, i) => (
            item.value && (
              <div class:list={["flex", i > 0 && "border-t"]} style="border-color: var(--border);">
                <div class="w-[100px] md:w-[120px] shrink-0 px-4 py-3 text-[12px] text-[var(--text-tertiary)]" style="background: var(--bg-alt);">
                  {item.label}
                </div>
                <div class="flex-1 px-4 py-3 text-[13px] text-[var(--text)]">
                  {item.label === '住所' ? (
                    <a href={mapLinkUrl} target="_blank" rel="noopener" class="text-[var(--text)] no-underline hover:opacity-60 transition-opacity">
                      {item.value}
                      <svg class="inline-block ml-1 align-text-bottom" width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M3 1h6v6M9 1L1 9" stroke="currentColor" stroke-width="1"/></svg>
                    </a>
                  ) : item.label === '電話' ? (
                    <a href={`tel:${item.value}`} class="text-[var(--text)] no-underline hover:opacity-60 transition-opacity">
                      {item.value}
                    </a>
                  ) : (
                    item.value
                  )}
                </div>
              </div>
            )
          ))}
        </div>
      </div>

      <!-- Tags -->
      {spot.data.tags && spot.data.tags.length > 0 && (
        <div class="mb-10 reveal">
          <div class="flex flex-wrap gap-2">
            {spot.data.tags.map((tag) => (
              <span class="text-[11px] px-3 py-1 rounded-[3px] text-[var(--text-tertiary)]" style="background: var(--bg-alt); border: 0.5px solid var(--border);">
                #{tag}
              </span>
            ))}
          </div>
        </div>
      )}

      <!-- Google Maps -->
      <div class="mb-10 reveal">
        <p class="label-text mb-4">Map</p>
        <div class="rounded-lg overflow-hidden" style="border: 0.5px solid var(--border);">
          <iframe
            src={mapEmbedUrl}
            width="100%"
            height="300"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
        <a
          href={mapLinkUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 mt-3 text-[12px] text-[var(--text-secondary)] no-underline hover:text-[var(--text)] transition-colors"
        >
          Google Mapsで開く
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M3 1h6v6M9 1L1 9" stroke="currentColor" stroke-width="1"/></svg>
        </a>
      </div>

      <!-- Affiliate Box -->
      {spot.data.affiliateType !== 'none' && (
        <AffiliateBox
          type={spot.data.affiliateType}
          spotName={spot.data.name}
          area={areaLabels[spot.data.area]}
        />
      )}

      <!-- Share -->
      <div class="mt-12 mb-8 pt-8 border-t" style="border-color: var(--border);">
        <p class="label-text mb-4">Share</p>
        <div class="flex items-center gap-6">
          <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(spot.data.name)}&url=${encodeURIComponent(`https://okinawa-go.jp/spots/${spot.id}/`)}&hashtags=沖縄旅行,OKINAWAGO`}
             target="_blank" rel="noopener"
             class="text-[12px] text-[var(--text-secondary)] no-underline hover:text-[var(--text)] transition-colors">
            X (Twitter)
          </a>
          <a href={`https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(`https://okinawa-go.jp/spots/${spot.id}/`)}`}
             target="_blank" rel="noopener"
             class="text-[12px] text-[var(--text-secondary)] no-underline hover:text-[var(--text)] transition-colors">
            LINE
          </a>
          <button id="copy-link"
             class="text-[12px] text-[var(--text-secondary)] hover:text-[var(--text)] transition-colors bg-transparent border-none cursor-pointer">
            Copy Link
          </button>
        </div>
      </div>
    </div>
  </article>

  <!-- Related Spots -->
  {relatedSpots.length > 0 && (
    <section class="px-5 md:px-10 pb-16 pt-16 max-w-[1200px] mx-auto border-t" style="border-color: var(--border); border-width: 0.5px;">
      <div class="reveal">
        <span class="label-text block mb-3">Related Spots</span>
        <h2 class="text-[22px] md:text-[28px] font-medium leading-[1.3] tracking-[-0.02em] text-[var(--text)] mb-10">関連スポット</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 reveal">
        {relatedSpots.map((s) => (
          <a href={`/spots/${s.id}/`} class="group block no-underline">
            <article class="h-full rounded-lg overflow-hidden transition-shadow duration-300 hover:shadow-[0_2px_20px_rgba(0,0,0,0.06)]" style="border: 0.5px solid var(--border);">
              <div class="relative w-full overflow-hidden" style="height: 160px;">
                <img
                  src={s.data.image}
                  alt={s.data.name}
                  class="w-full h-full object-cover transition-transform duration-600 group-hover:scale-[1.03]"
                  loading="lazy"
                />
              </div>
              <div class="p-4">
                <div class="flex items-center gap-2 mb-1">
                  <span class="font-['Inter'] text-[9px] tracking-[0.15em] uppercase text-[var(--text-tertiary)]">
                    {categoryLabels[s.data.category]}
                  </span>
                  <span class="text-[9px] text-[var(--text-muted)]">|</span>
                  <span class="text-[10px] text-[var(--text-tertiary)]">
                    {areaLabels[s.data.area]}
                  </span>
                </div>
                <h3 class="text-[15px] font-medium leading-[1.4] text-[var(--text)] transition-opacity duration-300 group-hover:opacity-60">
                  {s.data.name}
                </h3>
              </div>
            </article>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Related Articles -->
  {relatedArticles.length > 0 && (
    <section class="px-5 md:px-10 pb-20 md:pb-28 pt-16 max-w-[1200px] mx-auto border-t" style="border-color: var(--border); border-width: 0.5px;">
      <div class="reveal">
        <span class="label-text block mb-3">Related Articles</span>
        <h2 class="text-[22px] md:text-[28px] font-medium leading-[1.3] tracking-[-0.02em] text-[var(--text)] mb-10">関連記事</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-x-6 gap-y-10 reveal">
        {relatedArticles.map((article, i) => (
          <ArticleCardGrid
            slug={article.id}
            title={article.data.title}
            description={article.data.description}
            publishedAt={article.data.publishedAt}
            category={article.data.category}
            thumbnail={article.data.thumbnail}
            thumbnailAlt={article.data.thumbnailAlt}
            number={i + 1}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<script>
  document.getElementById('copy-link')?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(window.location.href);
    const btn = document.getElementById('copy-link');
    if (btn) { btn.textContent = 'Copied!'; setTimeout(() => btn.textContent = 'Copy Link', 2000); }
  });
</script>
