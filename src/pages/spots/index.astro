---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import { getCollection } from 'astro:content';

const spots = await getCollection('spots');

const categoryLabels: Record<string, string> = {
  restaurant: 'レストラン',
  cafe: 'カフェ',
  beach: 'ビーチ',
  activity: 'アクティビティ',
  hotel: 'ホテル',
  shopping: 'ショッピング',
  cultural: '文化・観光',
};

const areaLabels: Record<string, string> = {
  naha: '那覇',
  chatan: '北谷',
  yomitan: '読谷',
  onna: '恩納',
  nago: '名護',
  motobu: '本部',
  south: '南部',
  island: '離島',
};

const categoryKeys = Object.keys(categoryLabels);
const areaKeys = Object.keys(areaLabels);
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="スポットデータベース"
    description="沖縄のおすすめスポットを完全網羅。レストラン、カフェ、ビーチ、ホテルなどカテゴリ・エリア別に検索できます。"
  />

  <div class="px-5 md:px-10 pt-8 md:pt-12 max-w-[1200px] mx-auto pb-20 md:pb-28">
    <!-- Breadcrumb -->
    <nav class="mb-8 reveal">
      <ol class="flex items-center gap-2 font-['Inter'] text-[9px] tracking-[0.12em] uppercase text-[var(--text-tertiary)]">
        <li><a href="/" class="no-underline hover:text-[var(--text)] transition-colors duration-300">Home</a></li>
        <li>/</li>
        <li>Spots</li>
      </ol>
    </nav>

    <!-- Header -->
    <div class="mb-10 reveal">
      <span class="label-text block mb-3">Spot Database</span>
      <h1 class="text-[28px] md:text-[36px] font-medium leading-[1.3] tracking-[-0.02em] text-[var(--text)] mb-4">
        スポットデータベース
      </h1>
      <p class="text-[13px] leading-[1.7] text-[var(--text-secondary)] max-w-[600px]">
        沖縄のおすすめスポットをカテゴリ・エリア別に検索。レストラン、カフェ、ビーチ、アクティビティなど{spots.length}件のスポットを掲載。
      </p>
    </div>

    <!-- Filters -->
    <div class="mb-10 reveal" id="spot-filters">
      <!-- Category filter -->
      <div class="mb-4">
        <p class="font-['Inter'] text-[9px] tracking-[0.15em] uppercase text-[var(--text-tertiary)] mb-2">Category</p>
        <div class="flex flex-wrap gap-2">
          <button
            class="filter-btn category-btn active"
            data-category="all"
          >
            すべて
          </button>
          {categoryKeys.map((key) => (
            <button
              class="filter-btn category-btn"
              data-category={key}
            >
              {categoryLabels[key]}
            </button>
          ))}
        </div>
      </div>

      <!-- Area filter -->
      <div>
        <p class="font-['Inter'] text-[9px] tracking-[0.15em] uppercase text-[var(--text-tertiary)] mb-2">Area</p>
        <div class="flex flex-wrap gap-2">
          <button
            class="filter-btn area-btn active"
            data-area="all"
          >
            すべて
          </button>
          {areaKeys.map((key) => (
            <button
              class="filter-btn area-btn"
              data-area={key}
            >
              {areaLabels[key]}
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- Results count -->
    <p class="text-[12px] text-[var(--text-tertiary)] mb-6 reveal" id="results-count">
      {spots.length}件のスポット
    </p>

    <!-- Spot Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 reveal" id="spot-grid">
      {spots.map((spot) => (
        <a
          href={`/spots/${spot.id}/`}
          class="spot-card group block no-underline"
          data-category={spot.data.category}
          data-area={spot.data.area}
        >
          <article class="h-full rounded-lg overflow-hidden transition-shadow duration-300 hover:shadow-[0_2px_20px_rgba(0,0,0,0.06)]" style="border: 0.5px solid var(--border);">
            <div class="relative w-full overflow-hidden" style="height: 180px;">
              <img
                src={spot.data.image}
                alt={spot.data.name}
                class="w-full h-full object-cover transition-transform duration-600 group-hover:scale-[1.03]"
                loading="lazy"
              />
              {spot.data.recommended && (
                <span class="absolute top-3 left-3 font-['Inter'] text-[9px] tracking-[0.12em] text-white px-2 py-[3px] rounded-[2px]" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(4px);">
                  RECOMMENDED
                </span>
              )}
            </div>
            <div class="p-4">
              <div class="flex items-center gap-2 mb-2">
                <span class="font-['Inter'] text-[9px] tracking-[0.15em] uppercase text-[var(--text-tertiary)]">
                  {categoryLabels[spot.data.category]}
                </span>
                <span class="text-[9px] text-[var(--text-muted)]">|</span>
                <span class="text-[10px] text-[var(--text-tertiary)]">
                  {areaLabels[spot.data.area]}
                </span>
              </div>
              <h2 class="text-[16px] font-medium leading-[1.4] text-[var(--text)] mb-2 transition-opacity duration-300 group-hover:opacity-60">
                {spot.data.name}
              </h2>
              <p class="text-[11px] leading-[1.7] text-[var(--text-secondary)] line-clamp-2 mb-3">
                {spot.data.description}
              </p>
              <div class="flex items-center justify-between">
                {spot.data.budget && (
                  <span class="text-[11px] text-[var(--text-tertiary)]">{spot.data.budget}</span>
                )}
                <span class="inline-flex items-center gap-2 font-['Inter'] text-[10px] tracking-[0.08em] text-[var(--text-secondary)] transition-opacity duration-300 group-hover:opacity-60 ml-auto">
                  Detail
                  <span class="block w-3 h-[0.5px] bg-[var(--text-secondary)]"></span>
                </span>
              </div>
            </div>
          </article>
        </a>
      ))}
    </div>

    <!-- No results -->
    <p class="hidden text-center text-[13px] text-[var(--text-tertiary)] py-16" id="no-results">
      該当するスポットが見つかりませんでした。
    </p>
  </div>
</BaseLayout>

<style>
  .filter-btn {
    padding: 6px 14px;
    border-radius: 4px;
    font-size: 12px;
    background: var(--bg-alt);
    color: var(--text-secondary);
    border: 0.5px solid var(--border);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .filter-btn:hover {
    color: var(--text);
    border-color: var(--text-tertiary);
  }
  .filter-btn.active {
    background: var(--text);
    color: var(--bg);
    border-color: var(--text);
  }
</style>

<script>
  function initFilters() {
    const categoryBtns = document.querySelectorAll('.category-btn');
    const areaBtns = document.querySelectorAll('.area-btn');
    const cards = document.querySelectorAll('.spot-card') as NodeListOf<HTMLElement>;
    const resultsCount = document.getElementById('results-count');
    const noResults = document.getElementById('no-results');

    let activeCategory = 'all';
    let activeArea = 'all';

    function filterCards() {
      let count = 0;
      cards.forEach((card) => {
        const cat = card.dataset.category;
        const area = card.dataset.area;
        const matchCategory = activeCategory === 'all' || cat === activeCategory;
        const matchArea = activeArea === 'all' || area === activeArea;
        if (matchCategory && matchArea) {
          card.style.display = '';
          count++;
        } else {
          card.style.display = 'none';
        }
      });
      if (resultsCount) resultsCount.textContent = `${count}件のスポット`;
      if (noResults) {
        noResults.classList.toggle('hidden', count > 0);
      }
    }

    categoryBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        categoryBtns.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        activeCategory = (btn as HTMLElement).dataset.category || 'all';
        filterCards();
      });
    });

    areaBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        areaBtns.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        activeArea = (btn as HTMLElement).dataset.area || 'all';
        filterCards();
      });
    });
  }

  initFilters();
  document.addEventListener('astro:page-load', initFilters);
</script>
