---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import fs from 'node:fs';
import path from 'node:path';

const articlesPath = path.join(process.cwd(), 'src/data/articles.json');
let articles: any[] = [];
try {
  articles = JSON.parse(fs.readFileSync(articlesPath, 'utf-8')).filter((a: any) => a.status === 'published');
} catch {}

const categories = [
  { id: 'all', name: '全て' },
  { id: 'black-escape', name: 'ブラック企業脱出' },
  { id: 'job-change', name: '転職サイト比較' },
  { id: 'salary', name: '年収戦略' },
  { id: 'freelance', name: 'フリーランス独立' },
  { id: 'resume', name: '書類・面接' },
  { id: 'career', name: 'キャリア戦略' },
  { id: 'white-company', name: 'ホワイト企業' },
];

// Sort by date desc
articles.sort((a: any, b: any) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime());
---
<BaseLayout>
  <SEOHead slot="head" title="キャリア記事一覧 | キャリア孔明" description="キャリア戦略、転職、年収アップに関する記事一覧" />
  <div class="max-w-[1200px] mx-auto px-5 md:px-10 py-20">
    <h1 class="text-2xl md:text-3xl font-medium mb-8">キャリア記事</h1>

    <!-- Category filter -->
    <div class="flex flex-wrap gap-2 mb-10" id="category-filter">
      {categories.map(cat => (
        <button data-category={cat.id}
          class="px-4 py-2 text-xs border border-gray-200 rounded-full transition-colors hover:border-black category-btn">
          {cat.name}
        </button>
      ))}
    </div>

    <!-- Articles grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8" id="articles-grid">
      {articles.map((article: any) => (
        <a href={`/career/${article.slug}/`} class="group block no-underline" data-category={article.category}>
          <div class="aspect-[16/10] bg-gray-100 rounded-lg overflow-hidden mb-3">
            <div class="w-full h-full bg-gray-200 flex items-center justify-center text-gray-400 text-sm">
              {article.thumbnail ?
                <img src={article.thumbnail} alt={article.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" /> :
                'No Image'
              }
            </div>
          </div>
          <span class="label-text">{categories.find(c => c.id === article.category)?.name || article.category}</span>
          <h2 class="text-sm font-medium mt-1 mb-1 group-hover:opacity-60 transition-opacity">{article.title}</h2>
          <time class="meta-text">{article.publishedAt}</time>
        </a>
      ))}
    </div>

    {articles.length === 0 && (
      <p class="text-center text-gray-400 py-20">記事がまだありません</p>
    )}
  </div>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll('.category-btn');
  const articles = document.querySelectorAll('[data-category]');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.getAttribute('data-category');
      buttons.forEach(b => b.classList.remove('bg-black', 'text-white', 'border-black'));
      btn.classList.add('bg-black', 'text-white', 'border-black');

      document.querySelectorAll('#articles-grid > a').forEach(card => {
        if (cat === 'all' || card.getAttribute('data-category') === cat) {
          (card as HTMLElement).style.display = '';
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });
    });
  });

  // Set "all" as default active
  buttons[0]?.classList.add('bg-black', 'text-white', 'border-black');
</script>
